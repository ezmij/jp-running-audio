      "segments": [
        "audio/fuan-nou-transcript/015-1-sentence.mp3",
        "audio/fuan-nou-transcript/015-2-literal.mp3"
      ]
    },
    {
      "id": 16,
      "jp": "だんだん自分(じぶん)への信頼(しんらい)が薄(うす)れていきます。",
      "reading": "",
      "cn": "",
      "example": "",
