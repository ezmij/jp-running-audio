    },
    {
      "id": 17,
      "jp": "あれだけ考(かんが)えたのに何(なに)も変(か)えられなかった。",
      "reading": "",
      "cn": "",
      "example": "",
      "example_literal": "明明想了那麼多 卻 什麼 都 沒能改變。",
