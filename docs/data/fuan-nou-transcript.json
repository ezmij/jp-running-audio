        "audio/fuan-nou-transcript/120-2-literal.mp3"
      ]
    },
    {
      "id": 121,
      "jp": "ただその力(ちから)の向(む)かう先(さき)を少(すこ)しだけ変(か)えてあげることができたら、",
      "reading": "",
      "cn": "",
      "example": "",
      "example_literal": "只要 能夠 稍微 改變 那個力量 所朝向的 方向，",
