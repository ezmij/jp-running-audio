        "audio/fuan-nou-transcript/043-2-literal.mp3"
      ]
    },
    {
      "id": 44,
      "jp": "つまりあなたの脳(のう)は今(いま)この瞬間(しゅんかん)、来週(らいしゅう)の会議(かいぎ)を目(め)の前(まえ)の危機(きき)と同(おな)じように処理(しょり)しているかもしれない。",
      "reading": "",
      "cn": "",
      "example": "",
