        "audio/fuan-nou-transcript/003-2-literal.mp3"
      ]
    },
    {
      "id": 4,
      "jp": "やる気(き)がないわけじゃない。サボりたいわけでもない。",
      "reading": "",
      "cn": "",
      "example": "",
      "example_literal": "不是 沒有幹勁的 意思。也不是 想偷懶的 意思。",
