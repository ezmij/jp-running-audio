        "audio/fuan-nou-transcript/121-2-literal.mp3"
      ]
    },
    {
      "id": 122,
      "jp": "心配(しんぱい)を燃料(ねんりょう)にして小(ちい)さな行動(こうどう)に変(か)えていくことができたら、",
      "reading": "",
      "cn": "",
      "example": "",
