      "level": "",
      "segments": [
        "audio/fuan-nou-transcript/008-1-sentence.mp3",
        "audio/fuan-nou-transcript/008-2-literal.mp3"
      ]
    },
    {
      "id": 9,
      "jp": "心配(しんぱい)ばかりする人は慎重(しんちょう)で真面目(まじめ)な人だ。",
      "reading": "",
      "cn": "",
      "example": "",
      "example_literal": "只顧 擔心的人 是 謹慎 且 認真的人。",
