        "audio/fuan-nou-transcript/050-2-literal.mp3"
      ]
    },
    {
      "id": 51,
      "jp": "その２　心配(しんぱい)が強(つよ)い人は完璧(かんぺき)を求(もと)めるほど始(はじ)められなくなる。",
