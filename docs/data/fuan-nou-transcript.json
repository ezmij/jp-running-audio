      "segments": [
        "audio/fuan-nou-transcript/005-1-sentence.mp3",
        "audio/fuan-nou-transcript/005-2-literal.mp3"
      ]
    },
    {
      "id": 6,
      "jp": "気(き)がつけば1日(いちにち)が終(お)わっている。",
      "reading": "",
      "cn": "",
      "example": "",
