      "level": "",
      "segments": [
        "audio/fuan-nou-transcript/119-1-sentence.mp3",
        "audio/fuan-nou-transcript/119-2-literal.mp3"
      ]
    },
    {
      "id": 120,
      "jp": "それはあなたの中(なか)にあるとても誠実(せいじつ)な力(ちから)です。",
      "reading": "",
      "cn": "",
      "example": "",
      "example_literal": "那是 在你 裡面 的 非常 誠實的 力量。",
