      "level": "",
      "segments": [
        "audio/fuan-nou-transcript/009-1-sentence.mp3",
        "audio/fuan-nou-transcript/009-2-literal.mp3"
      ]
    },
    {
      "id": 10,
      "jp": "考(かんが)えてから行動(こうどう)するから失敗(しっぱい)が少(すく)ない。",
      "reading": "",
      "cn": "",
      "example": "",
      "example_literal": "思考過後 再行動 所以 失敗 少。",
